# Personal tailnet auth key (generate from https://login.tailscale.com/admin/settings/keys)
TS_AUTHKEY_PERSONAL=tskey-auth-xxxxx

# Work tailnet auth key (leave empty for interactive login)
TS_AUTHKEY_WORK=

# Hostnames for the machines in their respective tailnets
TS_HOSTNAME_PERSONAL=oglasnadeska-server
TS_HOSTNAME_WORK=jaka-bridge

# Target work machine IP to proxy all traffic to
TARGET_IP=100.102.61.116
